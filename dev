#!/usr/bin/env bash
set -euo pipefail

# AA2 local development script
# Usage:
#   ./dev          Build all + launch Godot
#   ./dev client   Build aa2-client only + launch Godot
#   ./dev run      Skip build, just launch Godot
#   ./dev check    cargo check + clippy + test (no Godot)
#   ./dev setup    Install Godot via Homebrew

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLIENT_DIR="$SCRIPT_DIR/client"

# Find Godot binary
find_godot() {
    if command -v godot &>/dev/null; then
        echo "godot"
    elif [ -f "/Applications/Godot.app/Contents/MacOS/Godot" ]; then
        echo "/Applications/Godot.app/Contents/MacOS/Godot"
    else
        echo ""
    fi
}

# Kill existing Godot process if running
kill_godot() {
    pkill -9 godot 2>/dev/null || true
    sleep 0.5
}

# Build the client (and dependencies as needed — cargo handles incremental)
build() {
    echo "→ Building aa2-client..."
    cargo build -p aa2-client
    # Copy dylib into client/bin/ so Godot can find it via res://
    mkdir -p "$CLIENT_DIR/bin"
    cp "$SCRIPT_DIR/target/debug/libaa2_client.dylib" "$CLIENT_DIR/bin/libaa2_client.dylib"
    echo "✓ Build complete"
}

# Launch Godot
launch() {
    local godot_bin
    godot_bin="$(find_godot)"
    if [ -z "$godot_bin" ]; then
        echo "✗ Godot not found. Run: ./dev setup"
        exit 1
    fi
    kill_godot
    echo "→ Launching Godot..."
    cd "$CLIENT_DIR"
    "$godot_bin" --path . 2>/dev/null &
    echo "✓ Godot running (PID $!)"
}

case "${1:-all}" in
    all)
        build
        launch
        ;;
    client)
        build
        launch
        ;;
    editor)
        build
        kill_godot
        echo "→ Opening Godot editor..."
        cd "$CLIENT_DIR"
        "$( find_godot)" --editor --path . &
        echo "✓ Editor running (PID $!)"
        ;;
    run)
        launch
        ;;
    check)
        echo "→ cargo check..."
        cargo check
        echo "→ cargo clippy..."
        cargo clippy -- -D warnings
        echo "→ cargo test..."
        cargo test
        echo "✓ All checks pass"
        ;;
    test)
        build
        godot_bin="$(find_godot)"
        if [ -z "$godot_bin" ]; then
            echo "✗ Godot not found. Run: ./dev setup"
            exit 1
        fi
        echo "→ Running integration tests..."
        cd "$CLIENT_DIR"
        "$godot_bin" --path . --script tests/test_runner.gd
        echo "✓ Integration tests complete"
        ;;
    net-smoke)
        echo "→ Building aa2-client + aa2-server..."
        cargo build -p aa2-client -p aa2-server
        mkdir -p "$CLIENT_DIR/bin"
        cp "$SCRIPT_DIR/target/debug/libaa2_client.dylib" "$CLIENT_DIR/bin/libaa2_client.dylib"
        echo "✓ Build complete"

        godot_bin="$(find_godot)"
        if [ -z "$godot_bin" ]; then
            echo "✗ Godot not found. Run: ./dev setup"
            exit 1
        fi

        # Start server in background (cwd = repo root so "data" resolves)
        "$SCRIPT_DIR/target/debug/aa2-server" &
        SERVER_PID=$!
        cleanup() { kill "$SERVER_PID" 2>/dev/null || true; }
        trap cleanup EXIT
        sleep 1

        echo "→ Running net smoke test..."
        set +e
        "$godot_bin" --headless --path "$CLIENT_DIR" --script tests/net_smoke.gd
        EXIT_CODE=$?
        set -e

        cleanup
        trap - EXIT
        exit $EXIT_CODE
        ;;
    setup)
        echo "→ Installing Godot via Homebrew..."
        if ! command -v brew &>/dev/null; then
            echo "✗ Homebrew not found. Install from https://brew.sh"
            exit 1
        fi
        brew install --cask godot
        echo "✓ Godot installed. Run: ./dev"
        ;;
    *)
        echo "Usage: ./dev [all|client|editor|run|check|test|net-smoke|setup]"
        echo ""
        echo "  all        Build all + launch Godot (default)"
        echo "  client     Build aa2-client + launch Godot"
        echo "  editor     Build + open Godot editor (inspect/debug)"
        echo "  run        Skip build, just launch Godot"
        echo "  check      cargo check + clippy + test"
        echo "  test       Build + run integration tests (requires display)"
        echo "  net-smoke  Build + run networked smoke test (server + headless client)"
        echo "  setup      Install Godot via Homebrew"
        exit 1
        ;;
esac
